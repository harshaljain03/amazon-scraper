# Database Configuration
DATABASE_URL=postgresql://scraper_user:scraper_password@localhost:5432/amazon_scraper
REDIS_URL=redis://localhost:6379/0

# CAPTCHA Service
TWOCAPTCHA_API_KEY=your_2captcha_api_key_here
CAPTCHA_SERVICE_URL=https://2captcha.com

# Scraper Configuration
SEARCH_QUERIES=wireless headphones,laptop backpack,coffee maker,fitness tracker,bluetooth speakers
MAX_PAGES_PER_QUERY=3
DELAY_BETWEEN_REQUESTS=2.0

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_TIME_WINDOW=60

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_BROWSER=chromium

# Monitoring
METRICS_HOST=0.0.0.0
METRICS_PORT=8080
LOG_LEVEL=INFO

# Proxy Configuration
PROXY_CONFIG_FILE=config/proxies.json
PROXY_ROTATION_INTERVAL=300
HEALTH_CHECK_INTERVAL=60
BLOCK_RATE_THRESHOLD=0.3

# Security
SECRET_KEY=your-secret-key-change-in-production

# Development
DEBUG=false
PYTHONPATH=/app
